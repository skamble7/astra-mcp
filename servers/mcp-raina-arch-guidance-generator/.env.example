# --- MCP Transport ---
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8004
MCP_MOUNT_PATH=/mcp

# --- Logging ---
SERVICE_NAME=mcp.raina.arch.guidance.generator
LOG_LEVEL=INFO

# --- Services ---
ARTIFACT_SERVICE_URL=http://host.docker.internal:9020

# --- LLM: ConfigForge mode ---
# CONFIG_FORGE_URL points at the ConfigForge service.
# Setting LLM_CONFIG_REF enables real LLM mode.
# Leave unset (or comment out) to get an error on startup (LLM is required).
CONFIG_FORGE_URL=http://host.docker.internal:8040
#LLM_CONFIG_REF=dev.llm.openai.fast
#LLM_CONFIG_REF=dev.llm.google_genai.flash
LLM_CONFIG_REF=dev.llm.bedrock.explicit-creds

# --- Output (local fallback) ---
OUTPUT_DIR=/tmp/arch-guidance-docs

# --- Storage: Garage (local S3-compatible) ---
# Use these settings when running against a local Garage instance.
# S3_ENDPOINT_URL must be set; path-style addressing is used automatically.
# S3_PUBLIC_BASE_URL exposes objects via Garage's public read port (3902).
S3_ENDPOINT_URL=http://host.docker.internal:3900
S3_REGION=garage
S3_ACCESS_KEY=astra-docs-key
S3_SECRET_KEY=0d5e17cb76bc132c05afdea4870db8ee44116c88e84b776ec419dc195ae1042e
S3_BUCKET=astra-docs                  # matches `garage bucket create astra-docs`
S3_PREFIX=arch-guidance-docs
S3_PUBLIC_BASE_URL=http://localhost:3902/astra-docs
S3_PUBLIC_READ=true

# --- Storage: AWS S3 ---
# To switch from Garage to AWS S3, comment out the Garage block above and
# uncomment the lines below. Key differences:
#   - Omit S3_ENDPOINT_URL entirely (boto3 routes to AWS automatically)
#   - Set S3_REGION to your bucket's region (e.g. us-east-1)
#   - Use real AWS credentials (IAM user or instance role)
#   - S3_PUBLIC_READ=true requires Block Public Access disabled on the bucket;
#     leave it false and rely on presigned URLs for private buckets
#   - S3_PUBLIC_BASE_URL can point to a CloudFront distribution for stable URLs;
#     leave unset to fall back to presigned URL delivery
#
# Required IAM permissions on the bucket:
#   s3:PutObject, s3:GetObject
#   s3:PutObjectAcl  (only if S3_PUBLIC_READ=true)
#
#S3_ENDPOINT_URL=                      # leave unset for native AWS
#S3_REGION=us-east-1
#S3_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
#S3_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
#S3_BUCKET=your-bucket-name
#S3_PREFIX=arch-guidance-docs
#S3_PUBLIC_BASE_URL=                   # unset, or set to CloudFront URL
#S3_PUBLIC_READ=false

# --- Pre-signed URL controls ---
# Used when S3_PUBLIC_BASE_URL is unset and S3_FORCE_SIGNED=true.
# S3_PRESIGN_BASE_URL overrides the endpoint used when signing URLs — set this
# to the public-facing host so signed URLs resolve from outside the container.
# For AWS S3, leave S3_PRESIGN_BASE_URL unset (AWS endpoint is used directly).
S3_FORCE_SIGNED=true
S3_PRESIGN_TTL_SECONDS=604800
S3_PRESIGN_BASE_URL=http://localhost:3900
# For AWS S3 presigned URLs, comment out S3_PRESIGN_BASE_URL:
#S3_PRESIGN_BASE_URL=

# --- Retrieval tuning (optional overrides) ---
# DOC_MAX_TURNS=15
# DOC_REQUEST_MAX_ITEMS=20
# DOC_SLICE_MAX_CHARS=14000
# DOC_TOTAL_RETRIEVED_MAX_CHARS=180000
