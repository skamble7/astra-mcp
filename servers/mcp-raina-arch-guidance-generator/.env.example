# --- MCP Transport ---
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8004
MCP_MOUNT_PATH=/mcp

# --- Logging ---
SERVICE_NAME=mcp.raina.arch.guidance.generator
LOG_LEVEL=INFO

# --- Services ---
ARTIFACT_SERVICE_URL=http://host.docker.internal:9020

# --- LLM: ConfigForge mode ---
# CONFIG_FORGE_URL points at the ConfigForge service.
# Setting LLM_CONFIG_REF enables real LLM mode.
# Leave unset (or comment out) to get an error on startup (LLM is required).
CONFIG_FORGE_URL=http://host.docker.internal:8040
#LLM_CONFIG_REF=dev.llm.openai.fast
#LLM_CONFIG_REF=dev.llm.google_genai.flash
LLM_CONFIG_REF=dev.llm.bedrock.explicit-creds

# --- Output (local fallback) ---
OUTPUT_DIR=/tmp/arch-guidance-docs

# --- Garage / S3 ---
S3_ENDPOINT_URL=http://host.docker.internal:3900
S3_REGION=garage
S3_ACCESS_KEY=astra-docs-key
S3_SECRET_KEY=0d5e17cb76bc132c05afdea4870db8ee44116c88e84b776ec419dc195ae1042e
S3_BUCKET=astra-docs                  # matches `garage bucket create astra-docs`
S3_PREFIX=arch-guidance-docs
S3_PUBLIC_BASE_URL=http://localhost:3902/astra-docs
S3_PUBLIC_READ=true

# --- Pre-signed URL controls ---
S3_FORCE_SIGNED=true
S3_PRESIGN_TTL_SECONDS=604800
S3_PRESIGN_BASE_URL=http://localhost:3900

# --- Retrieval tuning (optional overrides) ---
# DOC_MAX_TURNS=15
# DOC_REQUEST_MAX_ITEMS=20
# DOC_SLICE_MAX_CHARS=14000
# DOC_TOTAL_RETRIEVED_MAX_CHARS=180000
