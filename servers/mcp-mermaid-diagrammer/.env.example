# ──────────────────────────────
# MCP Transport
# ──────────────────────────────
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8001
# MCP_MOUNT_PATH=/mcp
# MCP_STATELESS_JSON=true

# ──────────────────────────────
# Logging
# ──────────────────────────────
LOG_LEVEL=INFO

# ──────────────────────────────
# ConfigForge — LLM configuration
# ──────────────────────────────
# URL of the ConfigForge service
CONFIG_FORGE_URL=http://host.docker.internal:8040

# ConfigForge canonical ref for the diagram LLM.
# Setting this enables real LLM mode (enable_real_llm=true).
# Leave unset (or comment out) to run in offline/dummy mode (no LLM calls).
#LLM_CONFIG_REF=dev.llm.openai.fast
#LLM_CONFIG_REF=dev.llm.google_genai.flash
LLM_CONFIG_REF=dev.llm.bedrock.explicit-creds
