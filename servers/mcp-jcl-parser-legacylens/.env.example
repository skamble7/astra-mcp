# servers/mcp-jcl-parser-legacylens/.env.example

# --- MCP transport ---
MCP_TRANSPORT=streamable-http
MCP_PORT=8876
MCP_MOUNT_PATH=/mcp

# --- Pagination & workers (parity with COBOL parser) ---
PAGE_SIZE=100
MAX_PAGE_SIZE=500
WORKERS=8

# --- Cache & logging ---
CACHE_DIR=/app/.cache
LOG_LEVEL=INFO

# --- Service naming (optional) ---
SERVICE_NAME=mcp.jcl.parser.legacylens

# --- LegacyLens specifics (put any knobs you’ll need later) ---
# LEGACYLENS_STRICT=true
# LEGACYLENS_DIALECT=zos
# LEGACYLENS_MAX_JOB_BYTES=1048576